{
  "manifest_version": 3,
  "name": "Mineradio Bridge",
  "version": "1.4.0",
  "description": "为 Mineradio 网页版提供本地音乐 API 代理，读取浏览器已登录的网易云/QQ/酷狗 Cookie。",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Mineradio Bridge",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": [
    "cookies",
    "storage",
    "scripting",
    "tabs",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "https://music.163.com/*",
    "https://*.music.163.com/*",
    "https://interface.music.163.com/*",
    "https://interface3.music.163.com/*",
    "https://y.qq.com/*",
    "https://*.y.qq.com/*",
    "https://u.y.qq.com/*",
    "https://c.y.qq.com/*",
    "https://ws.stream.qqmusic.qq.com/*",
    "https://*.gtimg.cn/*",
    "https://*.126.net/*",
    "http://*.126.net/*",
    "https://*.qq.com/*",
    "https://api.open-meteo.com/*",
    "https://api.qrserver.com/*",
    "http://ip-api.com/*",
    "https://ip-api.com/*",
    "https://*.kugou.com/*",
    "http://*.kugou.com/*",
    "https://*.kugou.net/*",
    "http://*.kugou.net/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://mineradio.art/*",
        "https://www.mineradio.art/*",
        "https://xxhuberrr.github.io/Mineradio/*",
        "http://localhost/*",
        "http://127.0.0.1/*",
        "http://[::1]/*"
      ],
      "js": ["content-bridge.js"],
      "run_at": "document_start"
    }
  ],
  "externally_connectable": {
    "matches": [
      "https://mineradio.art/*",
      "https://www.mineradio.art/*",
      "https://xxhuberrr.github.io/*",
      "http://localhost/*",
      "http://127.0.0.1/*",
      "http://[::1]/*"
    ]
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
